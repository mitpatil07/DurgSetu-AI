# ── Django Core ──────────────────────────────────────────────────────────────
# Generate a strong secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated list of allowed host/domain names
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Leave empty to use SQLite (development only).
# PostgreSQL example: postgres://user:password@host:5432/dbname
DATABASE_URL=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to make cross-site requests
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Rate Limiting (DRF throttle) ─────────────────────────────────────────────
THROTTLE_RATE_ANON=100/day
THROTTLE_RATE_USER=1000/day
THROTTLE_RATE_LOGIN=10/min
THROTTLE_RATE_FORGOT_PASSWORD=5/min

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ── AI / NVIDIA ───────────────────────────────────────────────────────────────
NVIDIA_API_KEY=

# ── Admin Security ────────────────────────────────────────────────────────────
# Secret required when registering a new admin account
ADMIN_REGISTRATION_SECRET=change-me-before-deployment
